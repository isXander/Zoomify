{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "contact": {
    "homepage": "https://isxander.dev",
    "issues": "https://github.com/isXander/Zoomify/issues",
    "sources": "https://github.com/isXander/Zoomify"
  },
  "icon": "assets/zoomify/zoomify.png",
  "license": "${mod_license}",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "adapter": "kotlin",
        "value": "dev.isxander.zoomify.Zoomify"
      }
    ],
    "modmenu": [
      {
        "adapter": "kotlin",
        "value": "dev.isxander.zoomify.integrations.ModMenuIntegration"
      }
    ],
    "controlify": [
      {
        "adapter": "kotlin",
        "value": "dev.isxander.zoomify.integrations.ControlifyIntegration"
      }
    ]
  },
  "mixins": [
    "zoomify.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.0",
    "fabric-language-kotlin": ">=1.13.8+kotlin.2.3.0",
    "minecraft": "${minecraft_dependency}",
    "java": ">=17",
    "yet_another_config_lib_v3": ">=3.6.6"
  },
  "suggests": {
    "modmenu": "*"
  },
  "breaks": {
    "optifabric": "*"
  }
}
