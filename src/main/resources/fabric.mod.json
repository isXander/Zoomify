{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "${description}",
  "authors": [
    "isXander"
  ],
  "contact": {
    "homepage": "https://isxander.dev",
    "issues": "https://github.com/isXander/Zoomify/issues",
    "sources": "https://github.com/isXander/Zoomify"
  },
  "icon": "assets/zoomify/zoomify.png",
  "license": "LGPLv3",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "adapter": "kotlin",
        "value": "dev.isxander.zoomify.Zoomify"
      }
    ],
    "modmenu": [
      {
        "adapter": "kotlin",
        "value": "dev.isxander.zoomify.integrations.ModMenuIntegration"
      }
    ],
    "controlify": [
      {
        "adapter": "kotlin",
        "value": "dev.isxander.zoomify.integrations.ControlifyIntegration"
      }
    ]
  },
  "mixins": [
    "zoomify.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric-language-kotlin": ">=1.13.4+kotlin.2.2.0",
    "minecraft": "${mc}",
    "java": ">=17",
    "yet_another_config_lib_v3": ">=3.7.0"
  },
  "suggests": {
    "modmenu": "*"
  },
  "breaks": {
    "optifabric": "*",
    "controlify": "<2.0.0-beta.9"
  }
}
